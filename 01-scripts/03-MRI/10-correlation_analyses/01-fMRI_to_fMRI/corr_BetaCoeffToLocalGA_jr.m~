%% corr_BetaCoeffToLocalGA_jr.m

% Script for correlation between the change in betas and the change in local graph
% metrics
% Reinwald, 06/2022

% Before running the script calculate beta coefficients and global metrics: 

% 1. run master_calculate_and_plot_mean_betas_jr.m to calculate and save
% beta coefficients in GLM folder (under respictive comparison, e.g. 
% TP_NoPuff_Bl3 vs TP_NoPuff_Bl1_11to40) --> mask_activation_Ins_T3485_v24.mat

% 2. run plot_pairedTT_globMetGA_reappraisal_jr.m to calculate and save
% global graph metrics in
% /home/jonathan.reinwald/ICON_Autonomouse/04-outputs/03-MRI/01-reappraisal/06-GA/cormat_v8/combined_hemisphere/bin_connected
% --> res_auc_struc.mat

%% Clearing
close all
clear all
clc

%% Comparison selection
name_TP1='TPnoPuff11to40';
name_TP2='TPnoPuff81to120';
% name_TP1='Odor11to40';
% name_TP2='TPnoPuff11to40';
% name_TP1='Odor81to120';
% name_TP2='TPnoPuff81to120';
% name_TP1='Odor11to40';
% name_TP2='Odor81to120';

%% Selection of input
% cormat version
cormat_version = 'cormat_v10';
% bi-/unihemispheric atlas
separated_hemisphere = 0;
% binarized/non-binarized network
binarization_method = 'max'; % 'max'
connectedness = 'connected';

%% Load beta coefficients (saved in script master_calculate_and_plot_mean_betas_jr.m)
% res.mat
load('/home/jonathan.reinwald/ICON_Autonomouse/03-processed-data/03-MRI/01-reappraisal/05-GLM/03-results/HRFlongTC_withoutOnset_from2sHRF-GLM_EPI_wave_10cons_med1000_msk_s6_wrst_a1_u_despiked_del5____ROI_v24___COV_v5___ORTH_1___DERDISP0___17-May-2022/secondlevel/TP_NoPuff_Bl3 vs TP_NoPuff_Bl1_11to40/mask_activation_Ins_T3_v24.mat');

%% Load global metrics (saved in plot_pairedTT_globMetGA_reappraisal_jr.m)
% res_auc_struc_global.mat -->  res_auc_struc
if separated_hemisphere==1
    load(['/home/jonathan.reinwald/ICON_Autonomouse/04-outputs/03-MRI/01-reappraisal/06-GA/' cormat_version filesep 'separated_hemisphere' filesep binarization_method '_' connectedness '/' name_TP1 'VS' name_TP2 '/res_auc_struc_local.mat']);
elseif separated_hemisphere==0
    load(['/home/jonathan.reinwald/ICON_Autonomouse/04-outputs/03-MRI/01-reappraisal/06-GA/' cormat_version filesep 'combined_hemisphere' filesep binarization_method '_' connectedness '/' name_TP1 'VS' name_TP2 '/res_auc_struc_local.mat']);
end
% define global metrics
local_metrics = fieldnames(res_auc_struc);

%% Load regional names
if separated_hemisphere==1
    load(['/home/jonathan.reinwald/ICON_Autonomouse/03-processed-data/03-MRI/01-reappraisal/06-FC/01-BASCO/' cormat_version '/beta4D/separated_hemisphere/roidata_' cormat_version(strfind(cormat_version,'v'):end) '_Odor81to120.mat']);
elseif separated_hemisphere==0
    load(['/home/jonathan.reinwald/ICON_Autonomouse/03-processed-data/03-MRI/01-reappraisal/06-FC/01-BASCO/' cormat_version '/beta4D/combined_hemisphere/roidata_' cormat_version(strfind(cormat_version,'v'):end) '_Odor81to120.mat']);    
end
names = {subj(1).roi.name};

%% Output directory
outputDir = fullfile('/home/jonathan.reinwald/ICON_Autonomouse/04-outputs/03-MRI/01-reappraisal/','07-correlation_analyses_fMRI_to_fMRI','01-GA_to_BetaCoeff');
if separated_hemisphere==1
    outputDir = fullfile('/home/jonathan.reinwald/ICON_Autonomouse/04-outputs/03-MRI/01-reappraisal/','07-correlation_analyses_fMRI_to_fMRI','01-GA_to_BetaCoeff',cormat_version,'separated_hemisphere',[binarization_method '_' connectedness],[name_TP1 'VS' name_TP2]);
elseif separated_hemisphere==0
    outputDir = fullfile('/home/jonathan.reinwald/ICON_Autonomouse/04-outputs/03-MRI/01-reappraisal/','07-correlation_analyses_fMRI_to_fMRI','01-GA_to_BetaCoeff',cormat_version,'combined_hemisphere',[binarization_method '_' connectedness],[name_TP1 'VS' name_TP2]);
end
mkdir(outputDir);
cd(outputDir);

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% STATISTICS for all local metrics
clear h_p p_p h_sp p_sp
% Loop over local metrics
for ix=1:length(local_metrics)   
    % Loop over regions of interes
    for jx=1:length(names)        
        [h_p(ix,jx),p_p(ix,jx)]=corr(([res.mean_betaPos]'-[res.mean_betaNeg]'),([res_auc_struc.(local_metrics{ix}).TPnoPuff81to120.(names{jx})]-[res_auc_struc.(local_metrics{ix}).TPnoPuff11to40.(names{jx})]),'type','Pearson');
        [h_sp(ix,jx),p_sp(ix,jx)]=corr(([res.mean_betaPos]'-[res.mean_betaNeg]'),([res_auc_struc.(local_metrics{ix}).TPnoPuff81to120.(names{jx})]-[res_auc_struc.(local_metrics{ix}).TPnoPuff11to40.(names{jx})]),'type','Spearman');
    end
end

%% Plot overview figure
% Figure
figure(1);
set(gcf,'Units','Normalized','OuterPosition',[0,0.04,0.35,0.7]);

% Subplot
sp1=subplot(1,4,1);
imagesc([p_p<0.05]');
% axes
ax=gca;
ax.XTick=[1:size(p_p,1)];
ax.XTickLabel=local_metrics;
ax.YTick=[1:size(p_p,2)];
ax.YTickLabel=names;
rotateXLabels(ax,90);
set(gca,'TickLabelInterpreter','none')
% Sign
[x1,y1]=find(p_p<.05);
for ix=1:length(x1)
    if p_p(x1(ix),y1(ix))<.001
        tx=text(x1(ix),y1(ix),'$');
        tx.FontSize=8;
    elseif p_p(x1(ix),y1(ix))<.01
        tx=text(x1(ix),y1(ix),'§');
        tx.FontSize=8;
    elseif p_p(x1(ix),y1(ix))<.05
        tx=text(x1(ix),y1(ix),'*');
        tx.FontSize=8;
    end
end
% title
tt=title(['Pearson (p<.05)']);

tx=text(-6,-1,'*: p<.05');
tx.FontSize=8;
tx=text(-6,-2,'§: p<.01');
tx.FontSize=8;
tx=text(-6,-3,'$: p<.001');
tx.FontSize=8;


% Subplot
sp2=subplot(1,4,2);
imagesc([h_p]');
% axes
ax=gca;
ax.XTick=[1:size(p_p,1)];
ax.XTickLabel=local_metrics;
ax.YTick=[1:size(p_p,2)];
ax.YTickLabel=names;
colormap(sp2,jet);
ax.CLim=[-0.6,0.6];
rotateXLabels(ax,90);
set(gca,'TickLabelInterpreter','none')
% title
tt=title(['Pearson (rho)']);

% Subplot
sp3=subplot(1,4,3);
imagesc([p_sp<0.05]');
% axes
ax=gca;
ax.XTick=[1:size(p_sp,1)];
ax.XTickLabel=local_metrics;
ax.YTick=[1:size(p_sp,2)];
ax.YTickLabel=names;
rotateXLabels(ax,90);
set(gca,'TickLabelInterpreter','none')
% Sign
[x1,y1]=find(p_sp<.05);
for ix=1:length(x1)
    if p_sp(x1(ix),y1(ix))<.001
        tx=text(x1(ix),y1(ix),'$');
        tx.FontSize=8;
    elseif p_sp(x1(ix),y1(ix))<.01
        tx=text(x1(ix),y1(ix),'§');
        tx.FontSize=8;
    elseif p_sp(x1(ix),y1(ix))<.05
        tx=text(x1(ix),y1(ix),'*');
        tx.FontSize=8;
    end
end
% title
tt=title(['Spearman (p<.05)']);

% Subplot
sp4=subplot(1,4,4);
imagesc([h_sp]');
% axes
ax=gca;
ax.XTick=[1:size(p_p,1)];
ax.XTickLabel=local_metrics;
ax.YTick=[1:size(p_p,2)];
ax.YTickLabel=names;
colormap(sp4,jet);
ax.CLim=[-0.6,0.6];
rotateXLabels(ax,90);
set(gca,'TickLabelInterpreter','none')
% title
tt=title(['Spearman (rho)']);

% print
print('-dpsc',fullfile(outputDir,['Correlation_BetaCoeffToLocalGA_overview']),'-painters','-r400');
print('-dpdf',fullfile(outputDir,['Correlation_BetaCoeffToLocalGA_overview']),'-painters','-r400');

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Insula plots
% Selection of local metrics and regions
clear local_metrics_selected regions_selected
local_metrics_selected = [find(contains(local_metrics,'l_cc') | contains(local_metrics,'l_PI'))]';
if separated_hemisphere == 0
    regions_selected = [find(contains(names,'I_dors') | contains(names,'I_ventr') | contains(names,'I_post'))];
elseif separated_hemisphere == 1
    regions_selected = [find(contains(names,'dIns') | contains(names,'vIns') | contains(names,'pIns'))];
end
% Set counter
counter_reg=1;
counter_fig=1;
clear h_p p_p h_sp p_sp

%% Loop over selected regions (Insula)
for jx=[regions_selected]
    % Set metrics counter
    counter_metrics=1;
    %% Loop over selected metrics
    for ix=[local_metrics_selected]
        % figure
        figure(counter_fig+1);
        set(gcf,'Units','Normalized','OuterPosition',[0,0.04,0.3,0.7]);
        % Statistics
        % 1. Pearson
        [h_p(counter_reg,counter_metrics),p_p(counter_reg,counter_metrics)]=corr(([res.mean_betaPos]'-[res.mean_betaNeg]'),([res_auc_struc.(local_metrics{ix}).TPnoPuff81to120.(names{jx})]-[res_auc_struc.(local_metrics{ix}).TPnoPuff11to40.(names{jx})]),'type','Pearson');
        % 2. Spearman
        [h_sp(counter_reg,counter_metrics),p_sp(counter_reg,counter_metrics)]=corr(([res.mean_betaPos]'-[res.mean_betaNeg]'),([res_auc_struc.(local_metrics{ix}).TPnoPuff81to120.(names{jx})]-[res_auc_struc.(local_metrics{ix}).TPnoPuff11to40.(names{jx})]),'type','Spearman');
        
        
        subplot(2,2,1:2);
        % scatter plot
        sc(1)=scatter(([res.mean_betaPos]'-[res.mean_betaNeg]'),([res_auc_struc.(local_metrics{ix}).TPnoPuff81to120.(names{jx})]-[res_auc_struc.(local_metrics{ix}).TPnoPuff11to40.(names{jx})]));
        sc(1).MarkerFaceAlpha=1; sc(1).SizeData=40;
        sc(1).MarkerFaceColor=[.8 .4 .4];
        sc(1).MarkerEdgeAlpha=1;
        sc(1).MarkerEdgeColor='none';
        % axes definition
        ax=gca;
        ax.XLabel.String = {'beta, insula (t>3.485)','(Bl3-Bl1)'};
        ax.YLabel.String = {[local_metrics{ix} ' of ' names{jx}],'(Bl3-Bl1)'};
        ax.XLabel.Interpreter='none';ax.YLabel.Interpreter='none';
        ax.LineWidth = 1.5;

        % line
        ll=lsline;
        ll.LineWidth=1.5;
        ll.Color=[.8 .4 .4];
        ll.LineStyle='--';
        % title
        tt=title(['Pearson']);
        tt.Interpreter='none';
        % text
        tx=text(ax.XLim(1)+diff(ax.XLim)*0.1,ax.YLim(1)+diff(ax.YLim)*0.1,['p=' num2str(round(p_p(counter_reg,counter_metrics),3))]);
        tx=text(ax.XLim(1)+diff(ax.XLim)*0.1,ax.YLim(1)+diff(ax.YLim)*0.2,['rho=' num2str(round(h_p(counter_reg,counter_metrics),3))]);
        
        % Subplot 2:
        subplot(2,2,3:4);
        % scatter plot
        clear A1 A2 B1 B2
        [~,A1]=sort([res.mean_betaPos]'-[res.mean_betaNeg]');
        [~,B1]=sort(A1);
        [~,A2]=sort([res_auc_struc.(local_metrics{ix}).TPnoPuff81to120.(names{jx})]-[res_auc_struc.(local_metrics{ix}).TPnoPuff11to40.(names{jx})]);
        [~,B2]=sort(A2);
        sc(1)=scatter(B1,B2);
        sc(1).MarkerFaceAlpha=1; sc(1).SizeData=40;
        sc(1).MarkerFaceColor=[.8 .4 .4];
        sc(1).MarkerEdgeAlpha=1;
        sc(1).MarkerEdgeColor='none';
        % axes definition
        ax=gca;
        ax.XLabel.String = {'beta, insula (t>3.485)','(rank, Bl3-Bl1)'};
        ax.YLabel.String = {[local_metrics{ix} ' of ' names{jx}],'(rank, Bl3-Bl1)'};
        ax.XLabel.Interpreter='none';ax.YLabel.Interpreter='none';
        ax.XLim=[0,25];
        ax.YLim=[0,25];
        ax.LineWidth = 1.5;

        % line
        ll=lsline;
        ll.LineWidth=1.5;
        ll.Color=[.8 .4 .4];
        ll.LineStyle='--';
        % title
        tt=title(['Spearman']);
        tt.Interpreter='none';
        % text
        tx=text(ax.XLim(1)+diff(ax.XLim)*0.1,ax.YLim(1)+diff(ax.YLim)*0.1,['p=' num2str(round(p_sp(counter_reg,counter_metrics),3))]);
        tx=text(ax.XLim(1)+diff(ax.XLim)*0.1,ax.YLim(1)+diff(ax.YLim)*0.2,['rho=' num2str(round(h_sp(counter_reg,counter_metrics),3))]);
        
        % counter update
        counter_metrics=counter_metrics+1;
        counter_fig=counter_fig+1;

        % print
        print('-dpsc',fullfile(outputDir,['Correlation_BetaCoeffToLocalGA_individualMetrics']),'-painters','-r400','-append');
        print('-dpdf',fullfile(outputDir,['Correlation_BetaCoeffToLocalGA_' local_metrics{ix} '_' names{jx}]),'-painters','-r400');
    end
    counter_reg=counter_reg+1;
end

close all